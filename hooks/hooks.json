{
  "description": "research-workflow HITL enforcement: deletion gate, test-integrity, no-silent-except, provenance, and no-secrets-in-git (all path-/command-scoped and self-limiting so they stay inert outside research code), plus evidence-before-done and no-stub-when-done Stop gates (main-agent-only by default; gate subagents too when RWF_SUBAGENT_EVIDENCE is set). Set RWF_HOOK_DEBUG=1 for a per-decision log (also records Skill-tool invocations, so the log shows which skills actually fire).",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {"type": "command", "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/test_integrity.sh", "timeout": 15},
          {"type": "command", "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/provenance.sh", "timeout": 15},
          {"type": "command", "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/no_silent_except.sh", "timeout": 15},
          {"type": "command", "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/myst_docs_hygiene.sh", "timeout": 15}
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {"type": "command", "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/deletion_gate.sh", "timeout": 10},
          {"type": "command", "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/no_secrets_in_git.sh", "timeout": 10}
        ]
      },
      {
        "matcher": "Skill",
        "hooks": [
          {"type": "command", "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/skill_activation.sh", "timeout": 5}
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {"type": "command", "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/session_check.sh", "timeout": 5}
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {"type": "command", "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/evidence_gate.sh", "timeout": 15},
          {"type": "command", "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/no_stub_when_done.sh", "timeout": 15}
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "*",
        "hooks": [
          {"type": "command", "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/evidence_gate.sh", "timeout": 15},
          {"type": "command", "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/no_stub_when_done.sh", "timeout": 15}
        ]
      }
    ]
  }
}
